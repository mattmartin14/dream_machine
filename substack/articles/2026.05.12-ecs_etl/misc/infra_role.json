{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "TerraformReadDiscovery",
            "Effect": "Allow",
            "Action": [
                "sts:GetCallerIdentity",
                "ec2:DescribeVpcs",
                "ec2:DescribeSubnets",
                "ec2:DescribeSecurityGroups",
                "ec2:DescribeVpcAttribute",
                "ec2:DescribeVpcs",
                "ec2:DescribeSubnets",
                "ecs:DescribeClusters",
                "ecs:DescribeTaskDefinition",
                "ecr:DescribeRepositories",
                "logs:DescribeLogGroups",
                "scheduler:GetSchedule",
                "scheduler:ListSchedules",
                "iam:GetRole",
                "iam:ListRolePolicies",
                "iam:ListAttachedRolePolicies",
                "iam:GetPolicy",
                "iam:GetPolicyVersion"
            ],
            "Resource": "*"
        },
        {
            "Sid": "ManageEcrRepo",
            "Effect": "Allow",
            "Action": [
                "ecr:CreateRepository",
                "ecr:DeleteRepository",
                "ecr:TagResource",
                "ecr:UntagResource",
                "ecr:ListTagsForResource"
            ],
            "Resource": "arn:aws:ecr:us-east-1:<aws-acct-id>:repository/ecs-duckdb-etl-test-repo"
        },
        {
            "Sid": "ManageCloudWatchLogGroup",
            "Effect": "Allow",
            "Action": [
                "logs:CreateLogGroup",
                "logs:DeleteLogGroup",
                "logs:PutRetentionPolicy",
                "logs:DeleteRetentionPolicy",
                "logs:TagLogGroup",
                "logs:UntagLogGroup",
                "logs:ListTagsLogGroup"
            ],
            "Resource": "arn:aws:logs:us-east-1:<aws-acct-id>:log-group:/ecs/ecs-duckdb-etl-test*"
        },
        {
            "Sid": "ManageEcsResources",
            "Effect": "Allow",
            "Action": [
                "ecs:CreateCluster",
                "ecs:DeleteCluster",
                "ecs:TagResource",
                "ecs:UntagResource",
                "ecs:RegisterTaskDefinition",
                "ecs:DeregisterTaskDefinition"
            ],
            "Resource": "*"
        },
        {
            "Sid": "ManageScheduler",
            "Effect": "Allow",
            "Action": [
                "scheduler:CreateSchedule",
                "scheduler:UpdateSchedule",
                "scheduler:DeleteSchedule",
                "scheduler:GetSchedule",
                "scheduler:TagResource",
                "scheduler:UntagResource",
                "scheduler:ListTagsForResource"
            ],
            "Resource": "arn:aws:scheduler:us-east-1:<aws-acct-id>:schedule/default/ecs-duckdb-etl-test-*"
        },
        {
            "Sid": "ManageSecurityGroup",
            "Effect": "Allow",
            "Action": [
                "ec2:CreateSecurityGroup",
                "ec2:DeleteSecurityGroup",
                "ec2:AuthorizeSecurityGroupEgress",
                "ec2:RevokeSecurityGroupEgress",
                "ec2:CreateTags",
                "ec2:DeleteTags"
            ],
            "Resource": "*"
        },
        {
            "Sid": "ManageIamRolesAndPoliciesForStack",
            "Effect": "Allow",
            "Action": [
                "iam:CreateRole",
                "iam:DeleteRole",
                "iam:UpdateAssumeRolePolicy",
                "iam:TagRole",
                "iam:UntagRole",
                "iam:CreatePolicy",
                "iam:DeletePolicy",
                "iam:TagPolicy",
                "iam:UntagPolicy",
                "iam:AttachRolePolicy",
                "iam:DetachRolePolicy"
            ],
            "Resource": [
                "arn:aws:iam::<aws-acct-id>:role/ecs-duckdb-etl-test-*",
                "arn:aws:iam::<aws-acct-id>:policy/ecs-duckdb-etl-test-*"
            ]
        },
        {
            "Sid": "PassOnlyStackRolesToRequiredServices",
            "Effect": "Allow",
            "Action": "iam:PassRole",
            "Resource": [
                "arn:aws:iam::<aws-acct-id>:role/ecs-duckdb-etl-test-execution-role",
                "arn:aws:iam::<aws-acct-id>:role/ecs-duckdb-etl-test-task-role",
                "arn:aws:iam::<aws-acct-id>:role/ecs-duckdb-etl-test-scheduler-role"
            ],
            "Condition": {
                "StringEquals": {
                    "iam:PassedToService": [
                        "ecs-tasks.amazonaws.com",
                        "scheduler.amazonaws.com"
                    ]
                }
            }
        },
        {
            "Sid": "AllowServiceLinkedRoleCreationIfMissing",
            "Effect": "Allow",
            "Action": "iam:CreateServiceLinkedRole",
            "Resource": "*",
            "Condition": {
                "StringLike": {
                    "iam:AWSServiceName": [
                        "ecs.amazonaws.com",
                        "ecs-tasks.amazonaws.com",
                        "scheduler.amazonaws.com"
                    ]
                }
            }
        },
        {
            "Sid": "EcrAuth",
            "Effect": "Allow",
            "Action": "ecr:GetAuthorizationToken",
            "Resource": "*"
        },
        {
            "Sid": "EcrPushToSpecificRepo",
            "Effect": "Allow",
            "Action": [
                "ecr:BatchCheckLayerAvailability",
                "ecr:CompleteLayerUpload",
                "ecr:DescribeRepositories",
                "ecr:InitiateLayerUpload",
                "ecr:PutImage",
                "ecr:UploadLayerPart",
                "ecr:BatchGetImage"
            ],
            "Resource": "arn:aws:ecr:us-east-1:<aws-acct-id>:repository/*"
        },
        {
            "Sid": "AllowUploadEtlScriptObject",
            "Effect": "Allow",
            "Action": [
                "s3:GetObject",
                "s3:GetObjectVersion",
                "s3:PutObject",
                "s3:DeleteObject",
                "s3:DeleteObjectVersion",
                "s3:AbortMultipartUpload",
                "s3:ListMultipartUploadParts",
                "s3:GetObjectTagging",
                "s3:PutObjectTagging",
                "s3:DeleteObjectTagging"
            ],
            "Resource": "arn:aws:s3:::s3-sales-agg-test/*"
        },
        {
            "Sid": "AllowReadLogGroupTags",
            "Effect": "Allow",
            "Action": [
                "logs:ListTagsForResource"
            ],
            "Resource": "arn:aws:logs:us-east-1:<aws-acct-id>:log-group:/ecs/*"
        },
        {
            "Sid": "TerraformDestroyIamPolicyVersionRead",
            "Effect": "Allow",
            "Action": [
                "iam:ListPolicyVersions"
            ],
            "Resource": [
                "arn:aws:iam::<aws-acct-id>:policy/ecs-duckdb-etl-test-task-s3",
                "arn:aws:iam::<aws-acct-id>:policy/ecs-duckdb-etl-test-scheduler-invoke"
            ]
        },
        {
            "Sid": "TerraformDestroyRoleInstanceProfileRead",
            "Effect": "Allow",
            "Action": [
                "iam:ListInstanceProfilesForRole"
            ],
            "Resource": "arn:aws:iam::<aws-acct-id>:role/ecs-duckdb-etl-test-scheduler-role"
        },
        {
            "Sid": "TerraformDestroyEc2EniRead",
            "Effect": "Allow",
            "Action": [
                "ec2:DescribeNetworkInterfaces"
            ],
            "Resource": "*"
        },
        {
            "Sid": "AllowListInstanceProfilesForEcsRoles",
            "Effect": "Allow",
            "Action": "iam:ListInstanceProfilesForRole",
            "Resource": [
                "arn:aws:iam::<aws-acct-id>:role/ecs-duckdb-etl-test-execution-role",
                "arn:aws:iam::<aws-acct-id>:role/ecs-duckdb-etl-test-task-role"
            ]
        }
    ]
}