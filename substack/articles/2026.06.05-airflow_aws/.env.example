# Copy to .env and edit values after Terraform has deployed foundation and runner task definitions.
AIRFLOW_UID=50000
AIRFLOW_ADMIN_USERNAME=airflow
AIRFLOW_ADMIN_PASSWORD=airflow
AIRFLOW_ADMIN_EMAIL=airflow@example.com

AWS_PROFILE=default
AWS_ACCT_ID=
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

AIRFLOW_ECS_CLUSTER=
AIRFLOW_ECS_TASK_DEFINITION=
AIRFLOW_ECS_CONTAINER_NAME=duckdb-runner-medium
AIRFLOW_ECS_SUBNETS=
AIRFLOW_ECS_SECURITY_GROUPS=
AIRFLOW_ECS_ASSIGN_PUBLIC_IP=ENABLED
AIRFLOW_ECS_LAUNCH_TYPE=FARGATE
AIRFLOW_ECS_AWS_CONN_ID=aws_default
AIRFLOW_ECS_REGION=us-east-1

SEED_SCRIPT_S3_URI=s3://s3-sales-agg-test/scripts/seed_tpch_raw_data.py
ORDERS_SCRIPT_S3_URI=s3://s3-sales-agg-test/scripts/orders_etl.py
CUST_SCRIPT_S3_URI=s3://s3-sales-agg-test/scripts/cust_etl.py
LINEITEM_SCRIPT_S3_URI=s3://s3-sales-agg-test/scripts/lineitem_etl.py
